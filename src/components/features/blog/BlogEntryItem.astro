---
import Card from "@components/ui/Card.astro";
import type { BlogEntry } from "utils/content";
import { formatDate } from "utils/time";
import { getBlogPathName } from "utils/url";
import { Image } from "astro:assets";

export type Props = BlogEntry;

const props = Astro.props;
---

<Card>
  <a class='block h-full rounded-lg focus:outline-none focus-visible:ring focus-visible:ring-primary-300 group' href={getBlogPathName(props)}>
    <div class="overflow-hidden rounded-2xl h-[220px]">
      <Image
        src={props.data.banner}
        decoding='async'
        loading='lazy'
        alt='blog banner'
        class="h-full w-full object-cover rounded-2xl opacity-0 transition-all duration-300 group-hover:scale-105"
        onload="this.style.opacity = 1"
      />
    </div>
    <div class='pt-2 flex flex-col items-start'>
      <div class='py-2'>
        <div class='flex items-center gap-0 bg-black text-white px-2 py-1 text-sm'>
          <h5>{props.data.readCount} - {formatDate(props.data.date)}</h5>
        </div>
      </div>
      <h4 class='text-black relative inline-block after:absolute after:left-0 after:bottom-0 after:h-[1.5px] after:w-0 after:bg-black after:transition-all after:duration-300 group-hover:after:w-full'>{props.data.title}</h4>
      <p class='mt-2 mb-0 text-sm text-gray-700'>{props.data.description}</p>
    </div>
  </a>
</Card>
