---
import type { ProjectEntry } from "utils/content";
import { Image } from "astro:assets";
import { getProjectPathName } from "utils/url";

export type Props = ProjectEntry;

const props = Astro.props;
const year = props.data.createdDate.getFullYear();
const tags = props.data.tags.slice(0, 2).map(t => t.toUpperCase()).join(' · ');
---

<a
  href={getProjectPathName(props)}
  class='group flex flex-col gap-0 focus:outline-none focus-visible:ring focus-visible:ring-primary-300'
>
  <div class="overflow-hidden rounded-2xl w-full aspect-[4/3]">
    <Image
      src={props.data.image}
      alt={props.data.title}
      width={800}
      height={600}
      decoding='async'
      loading='lazy'
      class="w-full h-full object-cover opacity-0 transition-all duration-500 group-hover:scale-105"
      onload="this.style.opacity = 1"
    />
  </div>
  <div class='pt-4 flex flex-col gap-2'>
    <div class='flex items-center justify-between gap-2'>
      {tags && (
        <span class='text-[11px] font-primary font-semibold uppercase tracking-widest border border-black/20 px-2 py-1 text-black/70 whitespace-nowrap'>
          {tags}
        </span>
      )}
      <span class='text-sm font-primary text-black/40 ml-auto flex-shrink-0'>{year}</span>
    </div>
    <h3 class='font-display text-2xl md:text-3xl text-black m-0 leading-tight group-hover:opacity-60 transition-opacity'>
      {props.data.title}
    </h3>
    <p class='text-sm text-gray-600 m-0 leading-relaxed line-clamp-2'>{props.data.description}</p>
  </div>
</a>
