---
const { tags, selectedTag, baseUrl } = Astro.props;
---

<div class="flex justify-center items-center flex-wrap gap-2 mb-6">
  <a 
    href={`/${baseUrl}`}
    class:list={[
      'mt-0 mb-2 h-6 md:h-8 px-2 md:px-3 w-max flex gap-2 items-center rounded-full text-xs md:text-sm',
      selectedTag == 'All' ? 'bg-black text-white border border-gray-800' :  'bg-black text-white hover:border hover:border-gray-800'
    ]}
  >
    All
  </a>
  {tags.map((tag) => (
    <a 
      href={`/${baseUrl}/${tag}`}
      class:list={[
        'mt-0 mb-2 h-6 md:h-8 px-2 md:px-3 w-max flex gap-2 items-center rounded-full text-xs md:text-sm',
        selectedTag === tag ? 'bg-black text-white border border-gray-800' : 'bg-black text-white hover:border hover:border-gray-800'
      ]}
    >
      # {tag}
    </a>
  ))}
</div>
