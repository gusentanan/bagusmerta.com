---
import ProjectEntryItem from "@components/features/project/ProjectEntryItem.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getProjectCollection } from "utils/content";
import { getTitle } from "utils/title";
import GradientSubText from "@components/ui/text/GradientSubText.astro";

const allProject = await getProjectCollection();
---
<BaseLayout title={getTitle('Projects')}>
    <main>
      <div class='layout pt-32 pb-8'>
        <div class="flex flex-col justify-center items-center">
          <h2 class='font-display text-3xl md:text-5xl text-center text-gradient-primary leading-tight pb-2'>
            Personal Projects
          </h2>

          <GradientSubText className="text-center">
            Things I've created in my free time.
          </GradientSubText>
        </div>
      </div>

      <div class='mt-0 pb-32 grid gap-8 sm:grid-cols-2 xl:grid-cols-2 px-4 sm:px-0 sm:w-11/12 sm:max-w-[60rem] sm:mx-auto'>
        {allProject.map((projects) => <ProjectEntryItem {...projects} />)}
      </div>
    </main>
</BaseLayout>
