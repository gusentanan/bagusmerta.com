---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getProjectCollection } from "utils/content";
import { getTitle } from "utils/title";
import { Image } from "astro:assets";
import { getProjectPathName } from "utils/url";

const allProject = await getProjectCollection();

const liveCount = allProject.filter(p => p.data.status === 'live').length;
const sinceYear = Math.min(...allProject.map(p => p.data.createdDate.getFullYear()));

const allCategories = [...new Set(allProject.flatMap(p => p.data.category ?? []))].sort();

const statusConfig: Record<string, { dot: string; label: string }> = {
  live:     { dot: 'bg-green-400',  label: 'LIVE' },
  sunset:   { dot: 'bg-amber-400',  label: 'SUNSET' },
  archived: { dot: 'bg-gray-400',   label: 'ARCHIVED' },
};

const featuredProject = allProject[0];
const restProjects = allProject.slice(1);
---

<BaseLayout title={getTitle('Projects')}>
  <main class="pb-28">

    <!-- Header -->
    <section class="pt-10 pb-10 text-center px-6">
      <article class="layout">
        <p class="text-xs font-primary uppercase tracking-widest text-black/40 mb-4">
          Personal Projects · {sinceYear} – Present
        </p>
        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl text-black m-0 leading-none mb-6">
          Things I've made.
        </h1>
        <p class="text-base text-gray-500 max-w-md mx-auto leading-relaxed">
          Some shipped, some shelved, all taught me something. Filter by what you're curious about.
        </p>
      </article>
    </section>

    <!-- Filter bar -->
    <section class="pb-8">
      <article class="layout">
        <div class="flex items-center justify-between flex-wrap gap-3">

          <!-- Pills -->
          <div class="flex items-center gap-2 flex-wrap">
            <button
              data-filter="all"
              class="filter-pill active font-primary text-sm px-4 py-1.5 rounded-full border border-black bg-black text-white transition-colors"
            >
              All
            </button>
            {allCategories.map(cat => (
              <button
                data-filter={cat}
                class="filter-pill font-primary text-sm px-4 py-1.5 rounded-full border border-black/20 text-black/60 hover:border-black/50 hover:text-black transition-colors capitalize"
              >
                {cat}
              </button>
            ))}
          </div>

          <!-- Stats -->
          <div class="flex items-center gap-2 text-sm font-primary text-black/40">
            <span id="project-count">{allProject.length} projects</span>
            <span>·</span>
            <span class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>
              <span id="live-count">{liveCount} live</span>
            </span>
          </div>

        </div>
      </article>
    </section>

    <!-- Project list -->
    <section>
      <article class="layout flex flex-col gap-6">

        <!-- Featured (first) project — full width -->
        {featuredProject && (() => {
          const s = statusConfig[featuredProject.data.status ?? 'archived'];
          return (
            <a
              href={getProjectPathName(featuredProject)}
              class="group project-card flex flex-col gap-4"
              data-categories={(featuredProject.data.category ?? []).join(',')}
            >
              <div class="relative overflow-hidden rounded-2xl aspect-[16/8]">
                <Image
                  src={featuredProject.data.image}
                  alt={featuredProject.data.title}
                  width={1200}
                  height={600}
                  decoding="async"
                  loading="eager"
                  class="w-full h-full object-cover opacity-0 transition-all duration-500 group-hover:scale-105"
                  onload="this.style.opacity = 1"
                />
                <div class="absolute top-4 left-4">
                  <span class="inline-flex items-center gap-1.5 bg-white/90 backdrop-blur-sm text-[11px] font-primary font-semibold uppercase tracking-widest px-2.5 py-1 rounded-full text-black">
                    <span class={`w-1.5 h-1.5 rounded-full ${s.dot}`}></span>
                    {s.label}
                  </span>
                </div>
              </div>
              <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between gap-4">
                  <div class="flex items-center gap-2 flex-wrap">
                    {featuredProject.data.tags.map(tag => (
                      <span class="text-[11px] font-primary font-semibold uppercase tracking-widest border border-black/20 px-2 py-1 text-black/70">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <span class="text-sm font-primary text-black/40 flex-shrink-0">
                    {featuredProject.data.createdDate.getFullYear()}
                  </span>
                </div>
                <h2 class="font-display text-4xl md:text-5xl text-black m-0 leading-tight group-hover:opacity-60 transition-opacity">
                  {featuredProject.data.title}
                </h2>
                <p class="text-sm text-gray-600 m-0 leading-relaxed max-w-xl">
                  {featuredProject.data.description}
                </p>
                {featuredProject.data.meta && (
                  <p class="text-[11px] font-primary text-black/40 mt-1 uppercase tracking-wide">
                    {featuredProject.data.meta}
                  </p>
                )}
              </div>
            </a>
          );
        })()}

        <!-- Rest of projects — 2-column grid -->
        <div id="projects-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-6 lg:gap-8">
          {restProjects.map(project => {
            const s = statusConfig[project.data.status ?? 'archived'];
            return (
              <a
                href={getProjectPathName(project)}
                class="group project-card flex flex-col gap-4"
                data-categories={(project.data.category ?? []).join(',')}
              >
                <div class="relative overflow-hidden rounded-2xl aspect-[4/3]">
                  <Image
                    src={project.data.image}
                    alt={project.data.title}
                    width={700}
                    height={525}
                    decoding="async"
                    loading="lazy"
                    class="w-full h-full object-cover opacity-0 transition-all duration-500 group-hover:scale-105"
                    onload="this.style.opacity = 1"
                  />
                  <div class="absolute top-4 left-4">
                    <span class="inline-flex items-center gap-1.5 bg-white/90 backdrop-blur-sm text-[11px] font-primary font-semibold uppercase tracking-widest px-2.5 py-1 rounded-full text-black">
                      <span class={`w-1.5 h-1.5 rounded-full ${s.dot}`}></span>
                      {s.label}
                    </span>
                  </div>
                </div>
                <div class="flex flex-col gap-2">
                  <div class="flex items-center justify-between gap-4">
                    <div class="flex items-center gap-2 flex-wrap">
                      {project.data.tags.map(tag => (
                        <span class="text-[11px] font-primary font-semibold uppercase tracking-widest border border-black/20 px-2 py-1 text-black/70">
                          {tag}
                        </span>
                      ))}
                    </div>
                    <span class="text-sm font-primary text-black/40 flex-shrink-0">
                      {project.data.createdDate.getFullYear()}
                    </span>
                  </div>
                  <h3 class="font-display text-3xl text-black m-0 leading-tight group-hover:opacity-60 transition-opacity">
                    {project.data.title}
                  </h3>
                  <p class="text-sm text-gray-600 m-0 leading-relaxed">
                    {project.data.description}
                  </p>
                  {project.data.meta && (
                    <p class="text-[11px] font-primary text-black/40 mt-1 uppercase tracking-wide">
                      {project.data.meta}
                    </p>
                  )}
                </div>
              </a>
            );
          })}
        </div>

        <!-- Empty state -->
        <div id="no-results" class="hidden text-center py-20">
          <p class="font-display text-2xl text-black/30">No projects in this category.</p>
        </div>

      </article>
    </section>

  </main>
</BaseLayout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');
  const projectCount = document.getElementById('project-count');
  const liveCount = document.getElementById('live-count');
  const noResults = document.getElementById('no-results');

  function setFilter(filter: string) {
    // Update pill styles
    pills.forEach(p => {
      const isActive = p.dataset.filter === filter;
      p.classList.toggle('bg-black', isActive);
      p.classList.toggle('text-white', isActive);
      p.classList.toggle('border-black', isActive);
      p.classList.toggle('text-black/60', !isActive);
      p.classList.toggle('border-black/20', !isActive);
    });

    // Filter cards
    let visible = 0;
    let visibleLive = 0;

    cards.forEach(card => {
      const categories = card.dataset.categories?.split(',') ?? [];
      const match = filter === 'all' || categories.includes(filter);
      card.style.display = match ? '' : 'none';
      if (match) {
        visible++;
        // Check if live (the status badge text inside the card)
        const badge = card.querySelector('[class*="bg-green"]');
        if (badge) visibleLive++;
      }
    });

    if (projectCount) projectCount.textContent = `${visible} projects`;
    if (liveCount) liveCount.textContent = `${visibleLive} live`;
    if (noResults) noResults.classList.toggle('hidden', visible > 0);
  }

  pills.forEach(pill => {
    pill.addEventListener('click', () => setFilter(pill.dataset.filter ?? 'all'));
  });
</script>
