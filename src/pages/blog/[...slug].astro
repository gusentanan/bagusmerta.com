---
import LatestPosts from "@components/features/blog/LatestPosts.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { formatDate } from "utils/time";
import Comments from "@components/ui/Comments.astro";
import { ImageEnhancer } from "@components/ui/ImageEnhancer";

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  const paths = blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
  return paths;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Extract the banner filename for OpenGraph (use public path for social media crawlers)
const bannerFilename = entry.data.banner.src.split('/').pop().split('.')[0] + '.jpg';
const ogBanner = `/blog-banners/${bannerFilename}`;
---

<BaseLayout
  title={`${entry.data.title} | I Putu Bagus Merta Sentana`}
  description={entry.data.description}
  banner={ogBanner}
  isBlog={true}
>
  <main class="max-w-4xl mx-auto px-6 md:px-8 pb-20">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-foreground/50 pt-8 pb-6">
      <a href="/blog" class="hover:text-foreground transition-colors">All Posts</a>
      <span>&rsaquo;</span>
      <span class="capitalize">{entry.data.tags[0]}</span>
    </nav>

    <!-- Title -->
    <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground leading-tight tracking-tight mb-4">
      {entry.data.title}
    </h1>

    <!-- Meta -->
    <p class="text-sm text-foreground/50 mb-8">
      {formatDate(entry.data.date)}
      <span class="mx-2">&middot;</span>
      by <span class="font-semibold text-foreground">Bagus Merta</span>
    </p>

    <!-- Banner Image -->
    <div class="w-full mb-10 rounded-xl overflow-hidden">
      <Image
        class="w-full h-auto object-cover opacity-0 transition-opacity duration-700 ease-out"
        src={entry.data.banner}
        width={1200}
        height={630}
        alt="Blog banner image"
        decoding="async"
        loading="eager"
        onload="this.style.opacity = 1"
      />
    </div>

    <!-- Content -->
    <article class="animate-fade-in-up-delay-2">
      <ImageEnhancer client:load>
        <div class="prose prose-lg max-w-none">
          <Content />
        </div>
      </ImageEnhancer>
    </article>

    <div class="animate-fade-in-up-delay-2">
      <Comments />
    </div>
    <div class="animate-fade-in-up-delay-2">
      <LatestPosts id={entry.data.id} />
    </div>
  </main>
</BaseLayout>
