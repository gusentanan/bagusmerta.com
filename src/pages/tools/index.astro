---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getTitle } from "utils/title";
import { JsonTools } from "@components/features/tools/JsonTools";
---

<BaseLayout title={getTitle("Tools")} description="Quick JSON utilities — format for readability or convert to TOON to save LLM tokens.">
  <main class="pb-28">

    <!-- Header -->
    <section class="pt-10 pb-10 text-center px-4">
      <p class="text-xs font-primary uppercase tracking-widest text-black/40 mb-4">
        Tools · JSON Utilities
      </p>
      <h1 class="font-display text-5xl md:text-6xl lg:text-7xl text-black m-0 leading-none mb-6">
        Handy little tools.
      </h1>
      <p class="text-base text-gray-500 max-w-lg mx-auto leading-relaxed">
        Format JSON for readability, or convert it to TOON — a compact notation that cuts LLM token usage by 30–60%.
      </p>
    </section>

    <!-- Interactive tool -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-10">
      <JsonTools client:only="react" />
    </section>

  </main>
</BaseLayout>
